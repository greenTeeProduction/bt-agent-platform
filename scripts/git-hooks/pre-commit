#!/bin/bash
# Pre-commit hook for go-bt-evolve
# Runs: gofmt check → go vet → go test -short
# Fails fast — blocks commit if any check fails.
# Install: make pre-commit-install

set -euo pipefail

GO="/usr/local/go/bin/go"
GOFMT="/usr/local/go/bin/gofmt"

# Detect if go is at standard location
if ! command -v "$GO" &>/dev/null; then
    GO="go"
    GOFMT="gofmt"
fi

echo "🔍 pre-commit: go-bt-evolve checks..."
echo ""

# 1. gofmt on staged Go files only
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -n "$STAGED_GO_FILES" ]; then
    echo "→ gofmt check on staged files..."
    UNFORMATTED=$($GOFMT -l $STAGED_GO_FILES 2>/dev/null || true)
    if [ -n "$UNFORMATTED" ]; then
        echo "✗ The following staged files need formatting:"
        echo "$UNFORMATTED"
        echo ""
        echo "  Run: make fmt"
        echo "  Then: git add <files>"
        exit 1
    fi
    echo "  ✓ formatted"
fi

# 2. go vet on the full project
echo "→ go vet..."
if ! $GO vet ./... 2>&1; then
    echo "✗ go vet found issues. Fix before committing."
    exit 1
fi
echo "  ✓ passed"

# 3a. Doc drift check if docs/ files are staged
STAGED_DOCS=$(git diff --cached --name-only --diff-filter=ACM | grep '^docs/' || true)
if [ -n "$STAGED_DOCS" ]; then
    echo "→ documentation drift check (docs/ changed)..."
    SCRIPT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
    if ! "$SCRIPT_DIR/scripts/check-doc-drift.sh" 2>&1; then
        echo "✗ Documentation drift detected. Update docs to match codebase."
        exit 1
    fi
    echo "  ✓ docs in sync"
fi

# 4. CI Doctor — validate workflow maturity (always runs, blocks commit on failure)
REPO_ROOT=$(git rev-parse --show-toplevel)
echo "→ ci-doctor workflow maturity check..."
if [ -f "$REPO_ROOT/bin/bt-ci-doctor" ]; then
    CI_DOCTOR_OUTPUT=$("$REPO_ROOT/bin/bt-ci-doctor" --root "$REPO_ROOT" 2>&1)
    CI_DOCTOR_EXIT=$?
    if [ $CI_DOCTOR_EXIT -ne 0 ]; then
        echo "✗ CI/CD workflow maturity check failed."
        echo "$CI_DOCTOR_OUTPUT" | grep '^✗'
        exit 1
    fi
    SUMMARY=$(echo "$CI_DOCTOR_OUTPUT" | head -1)
    echo "  ✓ $SUMMARY"
else
    echo "  ⚠ bt-ci-doctor not built — run 'make ci-doctor' first"
    echo "  → Attempting to build ci-doctor..."
    if "$GO" build -o "$REPO_ROOT/bin/bt-ci-doctor" ./cmd/bt-ci-doctor/ 2>/dev/null; then
        echo "  ✓ bt-ci-doctor built"
        CI_DOCTOR_OUTPUT=$("$REPO_ROOT/bin/bt-ci-doctor" --root "$REPO_ROOT" 2>&1)
        CI_DOCTOR_EXIT=$?
        if [ $CI_DOCTOR_EXIT -ne 0 ]; then
            echo "✗ CI/CD workflow maturity check failed."
            echo "$CI_DOCTOR_OUTPUT" | grep '^✗'
            exit 1
        fi
        SUMMARY=$(echo "$CI_DOCTOR_OUTPUT" | head -1)
        echo "  ✓ $SUMMARY"
    else
        echo "  ⚠ Could not build ci-doctor — skip with --no-verify if needed"
    fi
fi

# 5. Fast tests (no race — CI runs full -race; gardener skipped — known timeout)
echo "→ go test -short..."
if ! $GO test -short -count=1 -timeout 120s $(go list ./... | grep -v gardener) 2>&1; then
    echo "✗ Tests failed. Fix before committing."
    exit 1
fi
echo "  ✓ passed"

echo ""
echo "✅ pre-commit checks passed"
